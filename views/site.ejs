<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= site.businessName %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --brand:        #1a1a2e;
      --brand-light:  #16213e;
      --accent:       #e94560;
      --whatsapp:     #25d366;
      --whatsapp-dk:  #1da851;
      --call:         #3a86ff;
      --call-dk:      #2563eb;
      --text:         #1a1a2e;
      --text-muted:   #6b7280;
      --surface:      #ffffff;
      --bg:           #f8f9fc;
      --border:       #e5e7eb;
      --radius:       16px;
      --shadow-sm:    0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.06);
      --shadow-md:    0 4px 16px rgba(0,0,0,.10), 0 2px 6px rgba(0,0,0,.06);
      --shadow-lg:    0 10px 40px rgba(0,0,0,.14), 0 4px 12px rgba(0,0,0,.08);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
    }

    /* ── HERO ─────────────────────────────────────────── */
    .hero {
      background: linear-gradient(135deg, var(--brand) 0%, var(--brand-light) 60%, #0f3460 100%);
      padding: 64px 24px 56px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 50% at 20% 0%, rgba(233,69,96,.18) 0%, transparent 60%),
        radial-gradient(ellipse 60% 40% at 80% 100%, rgba(58,134,255,.15) 0%, transparent 55%);
      pointer-events: none;
    }

    .hero-badge {
      display: inline-block;
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.2);
      color: rgba(255,255,255,.85);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
      padding: 5px 14px;
      border-radius: 100px;
      margin-bottom: 20px;
      backdrop-filter: blur(8px);
    }

    .hero h1 {
      font-size: clamp(2rem, 8vw, 3.2rem);
      font-weight: 900;
      color: #fff;
      line-height: 1.1;
      letter-spacing: -.02em;
      margin-bottom: 16px;
    }

    .hero p {
      font-size: clamp(.95rem, 3.5vw, 1.1rem);
      color: rgba(255,255,255,.72);
      line-height: 1.65;
      max-width: 520px;
      margin: 0 auto 36px;
    }

    .cta-group {
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-width: 360px;
      margin: 0 auto;
    }

    .btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 16px 28px;
      border-radius: 14px;
      font-family: inherit;
      font-size: 1rem;
      font-weight: 700;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
      position: relative;
      overflow: hidden;
    }

    .btn::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(rgba(255,255,255,.12), transparent);
      pointer-events: none;
    }

    .btn:active { transform: scale(.97); }

    .btn-call {
      background: linear-gradient(135deg, var(--call), var(--call-dk));
      color: #fff;
      box-shadow: 0 4px 20px rgba(58,134,255,.45);
    }

    .btn-call:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(58,134,255,.55);
      filter: brightness(1.06);
    }

    .btn-whatsapp {
      background: linear-gradient(135deg, var(--whatsapp), var(--whatsapp-dk));
      color: #fff;
      box-shadow: 0 4px 20px rgba(37,211,102,.40);
    }

    .btn-whatsapp:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(37,211,102,.55);
      filter: brightness(1.06);
    }

    .btn span.emoji { font-size: 1.2em; line-height: 1; }

    /* ── DIVIDER WAVE ─────────────────────────────────── */
    .wave {
      display: block;
      width: 100%;
      height: 48px;
      background: var(--brand-light);
    }

    .wave-fill { fill: var(--bg); }

    /* ── GALLERY ──────────────────────────────────────── */
    .section {
      padding: 48px 24px;
      max-width: 900px;
      margin: 0 auto;
    }

    .section-title {
      font-size: 1.35rem;
      font-weight: 800;
      letter-spacing: -.02em;
      margin-bottom: 24px;
      color: var(--text);
    }

    .section-title span {
      display: inline-block;
      width: 4px;
      height: 1.2em;
      background: var(--accent);
      border-radius: 4px;
      margin-right: 10px;
      vertical-align: middle;
      position: relative;
      top: -1px;
    }

    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 14px;
    }

    .gallery-item {
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow-md);
      aspect-ratio: 4/3;
      background: var(--border);
      position: relative;
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform .35s ease;
    }

    .gallery-item:hover img { transform: scale(1.04); }

    /* single image → wider */
    .gallery.one-image { grid-template-columns: 1fr; max-width: 520px; }
    .gallery.one-image .gallery-item { aspect-ratio: 16/9; }

    /* ── CONTACT CARD ─────────────────────────────────── */
    .contact-card {
      background: var(--surface);
      border-radius: var(--radius);
      box-shadow: var(--shadow-md);
      padding: 28px 24px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .contact-row {
      display: flex;
      align-items: center;
      gap: 14px;
      text-decoration: none;
      color: var(--text);
      padding: 14px 16px;
      border-radius: 12px;
      border: 1.5px solid var(--border);
      font-weight: 600;
      font-size: .95rem;
      transition: border-color .18s, background .18s, transform .18s;
    }

    .contact-row:hover {
      background: var(--bg);
      border-color: var(--accent);
      transform: translateX(4px);
    }

    .contact-icon {
      font-size: 1.4rem;
      line-height: 1;
      flex-shrink: 0;
    }

    .contact-label {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .contact-label small {
      font-size: .75rem;
      font-weight: 500;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: .06em;
    }

    /* ── FOOTER ───────────────────────────────────────── */
    footer {
      text-align: center;
      padding: 32px 24px;
      color: var(--text-muted);
      font-size: .8rem;
      border-top: 1px solid var(--border);
      margin-top: 16px;
    }

    footer a {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
    }

    /* ── RESPONSIVE ───────────────────────────────────── */
    @media (min-width: 480px) {
      .cta-group { flex-direction: row; }
      .btn { flex: 1; }
    }

    @media (min-width: 768px) {
      .hero { padding: 88px 40px 72px; }
      .section { padding: 56px 40px; }
    }
  </style>
</head>
<body>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-badge">Бизнес-страница</div>
    <h1><%= site.businessName %></h1>
    <% if (site.description) { %>
      <p><%= site.description %></p>
    <% } %>
    <div class="cta-group">
      <% if (site.phone) { %>
        <a class="btn btn-call" href="tel:<%= site.phone.replace(/\s+/g, '') %>">
          <span class="emoji">📞</span> Позвонить
        </a>
      <% } %>
      <% if (site.whatsapp) { %>
        <a class="btn btn-whatsapp" href="https://wa.me/<%= site.whatsapp.replace(/[^\d]/g, '') %>" target="_blank" rel="noopener">
          <span class="emoji">💬</span> WhatsApp
        </a>
      <% } %>
    </div>
  </section>

  <!-- WAVE DIVIDER -->
  <svg class="wave" viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path class="wave-fill" d="M0,48 C360,0 1080,0 1440,48 L1440,48 L0,48 Z"/>
  </svg>

  <!-- GALLERY -->
  <% if (site.images && site.images.length > 0) { %>
    <div class="section">
      <h2 class="section-title"><span></span>Фотографии</h2>
      <div class="gallery <%= site.images.length === 1 ? 'one-image' : '' %>">
        <% site.images.forEach(img => { %>
          <div class="gallery-item">
            <img src="<%= img %>" alt="<%= site.businessName %>" loading="lazy">
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <!-- CONTACT -->
  <% if (site.phone || site.whatsapp) { %>
    <div class="section" style="padding-top: 0">
      <h2 class="section-title"><span></span>Контакты</h2>
      <div class="contact-card">
        <% if (site.phone) { %>
          <a class="contact-row" href="tel:<%= site.phone.replace(/\s+/g, '') %>">
            <span class="contact-icon">📞</span>
            <span class="contact-label">
              <small>Телефон</small>
              <%= site.phone %>
            </span>
          </a>
        <% } %>
        <% if (site.whatsapp) { %>
          <a class="contact-row" href="https://wa.me/<%= site.whatsapp.replace(/[^\d]/g, '') %>" target="_blank" rel="noopener">
            <span class="contact-icon">💬</span>
            <span class="contact-label">
              <small>WhatsApp</small>
              <%= site.whatsapp %>
            </span>
          </a>
        <% } %>
      </div>
    </div>
  <% } %>

  <!-- FOOTER -->
  <footer>
    Создано с помощью <a href="/">SiteRocket</a>
  </footer>

</body>
</html>

<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>SiteRocket — Admin Login</title>
  <style>
    body { font-family: sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: #f5f5f5; }
    .box { background: #fff; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.15); width: 320px; }
    h2 { margin: 0 0 1.5rem; font-size: 1.2rem; }
    input[type=password] { width: 100%; padding: .6rem; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; font-size: 1rem; }
    button { margin-top: 1rem; width: 100%; padding: .7rem; background: #111; color: #fff; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; }
    button:hover { background: #333; }
    .error { color: #c00; font-size: .9rem; margin-top: .75rem; }
  </style>
</head>
<body>
  <div class="box">
    <h2>Admin Panel</h2>
    <form method="POST" action="/admin/login">
      <input type="password" name="password" placeholder="Пароль" autofocus>
      <button type="submit">Войти</button>
      <% if (error) { %>
        <p class="error"><%= error %></p>
      <% } %>
    </form>
  </div>
</body>
</html>

# Cloudinary — get from cloudinary.com → Dashboard → "API Keys"
# Copy the full URL shown under "API environment variable"
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# MongoDB Atlas — get from atlas.mongodb.com → Connect → Drivers → copy connection string
# Replace <password> and <dbname> with your values
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/siterocket?retryWrites=true&w=majority
